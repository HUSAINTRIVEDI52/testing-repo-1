    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "antd": "^5.18.0",
    "axios": "^1.7.2",
    "babel-jest": "^29.7.0",
    "cs-pack": "^1.1.38",
    "date-fns": "^4.1.0",
    "enzyme": "^3.11.0",
    "jsdom": "^24.1.0",
    "lottie-react": "^2.4.1",
    "markdown-to-jsx": "^7.4.7",
    "posthog-js": "^1.290.0",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
