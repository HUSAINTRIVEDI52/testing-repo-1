    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.51.5",
    "react-joyride": "^2.9.3",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^6.23.1",
    "react-scripts": "5.0.1",
    "rtf.js": "^3.0.9",
    "sass": "^1.77.4",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^4.9.5",
    "util": "^0.12.5",
    "uuid": "^10.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "jest",
    "eject": "craco eject",
    "coverage": "jest --coverage",
    "build:theta": "node scripts/version-manager.js --strategy=calver && craco build",
    "release:major": "node scripts/version-manager.js --strategy=semver --bump=major && craco build",
    "release:minor": "node scripts/version-manager.js --strategy=semver --bump=minor && craco build",
    "release:patch": "node scripts/version-manager.js --strategy=semver --bump=patch && craco build",
    "prepare": "node -e \"const {spawnSync}=require(\\\"child_process\\\");const r=spawnSync(process.platform===\\\"win32\\\"?\\\"npx.cmd\\\":\\\"npx\\\",[\\\"--no-install\\\",\\\"husky\\\"],{stdio:\\\"inherit\\\"});process.exit((r.status===0||r.status===null)?0:0)\"",
    "lint": "npx eslint .",
    "test:smoke": "npx jest --coverage --coverageReporters=lcov text",
    "test:newman": "newman run *.postman_collection.json --reporters cli,htmlextra --reporter-htmlextra-export newman-report.html --bail",
    "test:all": "npm run test:smoke && npm run test:newman"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "ignoreRestSiblings": true
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.7",
    "@jest/globals": "^29.7.0",
    "@testing-library/dom": "^10.3.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/enzyme": "^3.10.18",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-gtm-module": "^2.0.4",
    "@types/react-helmet": "^6.1.11",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/turndown": "^5.0.4",
    "@types/uuid": "^10.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-css-modules-transform": "^4.4.2",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
